# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
data/

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# syncthing files
.stfolder

chatlog.exe
wetrace.exe

# 本地调试/测试用的一次性命令
cmd/

# Added by goreleaser init:
dist/
.idea/
bad_cache_list.txt
ffmpeg/ffmpeg.exe

# sensevoiced 侧车：代码（server.py / start.ps1 / stop.ps1 / README.md）入库；
# 但运行时产物（私有 Python、模型缓存、日志、临时音频）忽略掉。
sensevoiced/python/
sensevoiced/models/
sensevoiced/tmp/
sensevoiced/*.log
sensevoiced/*.err.log
sensevoiced/__pycache__/

# wetrace 自身运行时日志（含本机绝对路径、调试上下文）
wetrace.log
wetrace.err.log
wetrace.db

# 聊天导出 / 一次性调试 dump（含真实 wxid、昵称、聊天明文，绝对不能入库）
chat_export_*
wx_msgs*.json
wxid_*.json
*.dump.json